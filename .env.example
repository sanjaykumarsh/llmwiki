# LLMwiki Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Required Configuration
# ==========================================

# Google Gemini API Key (get from https://ai.google.dev/)
GEMINI_API_KEY=AIzaSy_your_actual_api_key_here

# JWT Secret Key for authentication (change this!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters

# ==========================================
# Optional Configuration
# ==========================================

# Database URL (default: SQLite)
# SQLite (development/testing):
DATABASE_URL=sqlite:///./llmwiki.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost:5432/llmwiki

# Application
LOG_LEVEL=info
DEBUG=False

# CORS settings
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,https://yourdomain.com

# Session settings
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# Docker-specific settings
# ==========================================

# For docker-compose, these are optional (defaults are fine)
COMPOSE_PROJECT_NAME=llmwiki
COMPOSE_FILE=docker-compose.yml
